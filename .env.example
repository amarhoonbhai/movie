# ── Bot Credentials ────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
API_ID=your_api_id
API_HASH=your_api_hash

# ── TMDb Metadata (Required) ──────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key

# ── MongoDB Connection (Required) ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/movie_bot?retryWrites=true&w=majority
DB_NAME=movie_bot

# ── Ownership & Access ────────────────────────────────────────────────────────
OWNER_ID=123456789
ADMIN_IDS=123456789,987654321
ALLOWED_GROUP=-1001234567890

# ── Developer & Support (Optional) ───────────────────────────────────────────
DEV_USERNAME=@kurup
SUPPORT_GROUP=https://t.me/YourSupportGroup
SUPPORT_CHANNEL=https://t.me/YourSupportChannel

# ── Storage & Force-Subscribe ─────────────────────────────────────────────────
# The private channel where movies are indexed from
STORAGE_CHANNEL=-1009876543210

# The channel users must join before using the bot
FSUB_CHANNEL=@YourForceSubChannel
FSUB_LINK=https://t.me/YourForceSubChannel

# ── UI (Optional) ─────────────────────────────────────────────────────────────
BANNER_URL=https://graph.org/file/f47a79f0a69e48a0eb5d5.jpg
AUTO_DELETE_TIMER=600
